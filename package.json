{
  "name": "komado",
  "version": "0.1.1",
  "description": "A terminal manga reader (MangaDex + local files) rendered with Ink.",
  "keywords": [
    "manga",
    "mangadex",
    "reader",
    "terminal",
    "tui",
    "cli",
    "sixel",
    "cbz",
    "comic"
  ],
  "type": "module",
  "bin": {
    "komado": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "node scripts/build.mjs",
    "prestart": "node scripts/build.mjs",
    "start": "node dist/cli.js",
    "dev": "node scripts/build.mjs && node dist/cli.js",
    "doctor": "node scripts/build.mjs && node dist/cli.js doctor",
    "lint": "eslint src test",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RyuPrad/komado.git"
  },
  "homepage": "https://github.com/RyuPrad/komado#readme",
  "bugs": "https://github.com/RyuPrad/komado/issues",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "node-unrar-js": "^2.0.2",
    "react": "^18.3.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "ink-testing-library": "^4.0.0",
    "vitest": "^3.2.6"
  }
}
